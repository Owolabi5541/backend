{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["apps/*", "libs/*"],
  "scripts": {
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "migrate:reset": "npx dotenv-cli -e .env -- prisma migrate reset --force --skip-seed --schema=libs/prisma/user/schema.prisma && npx dotenv-cli -e .env -- prisma migrate reset --force --skip-seed --schema=libs/prisma/wallet/schema.prisma",
    "migrate:reset:user": "npx dotenv-cli -e .env -- prisma migrate reset --force --skip-seed --schema=libs/prisma/user/schema.prisma",
    "migrate:reset:wallet": "npx dotenv-cli -e .env -- prisma migrate reset --force --skip-seed --schema=libs/prisma/wallet/schema.prisma",
    "migrate:dev": "npx dotenv-cli -e .env -- prisma migrate dev --schema=libs/prisma/user/schema.prisma && npx dotenv-cli -e .env -- prisma migrate dev --schema=libs/prisma/wallet/schema.prisma",
    "generate": "npx dotenv-cli -e .env -- prisma generate --schema=libs/prisma/user/schema.prisma && npx dotenv-cli -e .env -- prisma generate --schema=libs/prisma/wallet/schema.prisma",
    "prisma:generate": "npm run generate",
    "prisma:migrate:user": "npm run prisma:migrate:user -w @ass-end/prisma",
    "prisma:migrate:wallet": "npm run prisma:migrate:wallet -w @ass-end/prisma",
    "prisma:studio:user": "npm run prisma:studio:user -w @ass-end/prisma",
    "prisma:studio:wallet": "npm run prisma:studio:wallet -w @ass-end/prisma",
    "dev:users": "npm run start:dev -w users",
    "dev:wallet": "npm run start:dev -w wallet",
    "dev:gateway": "npm run start:dev -w gateway"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.6",
    "@grpc/proto-loader": "^0.7.15",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.6.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nestjs-pino": "^4.4.0",
    "pino-http": "^10.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.14.1",
    "dotenv-cli": "^8.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.6.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
