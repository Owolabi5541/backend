{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "baseUrl": ".",
    "paths": {
      "@backend/proto": ["libs/proto/src"],
      "@backend/prisma": ["libs/prisma/src"],
      "@backend/logger": ["libs/logger/src"]
    }
  }
}
