generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma/wallet-client"
}

datasource db {
  provider = "postgresql"
  url      = env("WALLET_DATABASE_URL")
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Float    @default(0)
  createdAt DateTime @default(now())
}
